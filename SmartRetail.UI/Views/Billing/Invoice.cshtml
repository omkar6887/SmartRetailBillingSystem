@model SmartRetail.UI.Models.InvoiceViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Invoice - @Model.BillNumber</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f8f9fa;
            padding: 30px 0;
        }

        .invoice-card {
            background: #ffffff;
            border: none;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            overflow: hidden;
        }

        .invoice-header {
            background: #0d6efd; /* Modern Bootstrap Blue */
            color: white;
            padding: 40px;
            text-align: center;
        }

        .invoice-body {
            padding: 40px;
        }

        .table thead {
            background-color: #f1f4f9;
        }

        .table th {
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 1px;
            border: none;
        }

        .total-section {
            background-color: #f8f9fa;
            padding: 20px;
            border-radius: 10px;
            margin-top: 20px;
        }

        .grand-total-label {
            font-weight: 700;
            font-size: 1.2rem;
            color: #0d6efd;
        }

        .thank-you-footer {
            text-align: center;
            padding: 30px;
            color: #6c757d;
            font-style: italic;
        }

        /* Print Optimization */
        @@media print {
            body { background: white; padding: 0; }
            .invoice-card { box-shadow: none; border: 1px solid #eee; }
            .btn-print, .print-hide { display: none !important; }
            .invoice-header { background: #000 !important; color: white !important; -webkit-print-color-adjust: exact; }
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card invoice-card">

                    <div class="invoice-header">
                        <h1 class="fw-bold mb-1">OmniStore RETAIL</h1>
                        <p class="mb-0 opacity-75">Quality Products • Best Service</p>
                    </div>

                    <div class="invoice-body">
                        <div class="row mb-4">
                            <div class="col-sm-6">
                                <h6 class="text-muted text-uppercase fw-bold">Invoice To:</h6>
                                <p class="mb-0"><strong>Cash Customer</strong></p>
                                <p class="text-muted small">Store Location: Main Branch</p>
                            </div>
                            <div class="col-sm-6 text-sm-end">
                                <h6 class="text-muted text-uppercase fw-bold">Details:</h6>
                                <p class="mb-0"><strong>No:</strong> #@Model.BillNumber</p>
                                <p class="mb-0"><strong>Date:</strong> @Model.BillDate.ToString("dd MMM yyyy")</p>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead>
                                    <tr>
                                        <th class="ps-0">Product Name</th>
                                        <th class="text-center">Qty</th>
                                        <th class="text-end">Unit Price</th>
                                        <th class="text-end">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Items)
                                    {
                                        <tr>
                                            <td class="ps-0 fw-semibold">@item.ProductName</td>
                                            <td class="text-center">@item.Quantity</td>
                                            <td class="text-end">Rs.@item.Price</td>
                                            <td class="text-end fw-bold">Rs.@item.Total</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="row justify-content-end">
                            <div class="col-md-5">
                                <div class="total-section d-flex justify-content-between align-items-center">
                                    <span class="grand-total-label">Grand Total</span>
                                    <span class="grand-total-label">₹@Model.GrandTotal</span>
                                </div>
                            </div>
                        </div>

                        <div class="text-center mt-5 print-hide">
                            <button onclick="window.print()" class="btn btn-primary btn-lg px-5 shadow-sm btn-print">
                                <i class="bi bi-printer"></i> Print Invoice
                            </button>
                        </div>
                    </div>

                    <div class="thank-you-footer border-top">
                        <p class="mb-0">Thank you for shopping with us! Visit again.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>